# Data files - don't commit large datasets
data/raw/
data/processed/
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.tiff
*.webp

# Allow images in docs/ for GitHub Pages
!docs/**/*.png
!docs/**/*.jpg

# But keep directory structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/raw/real/.gitkeep
!data/raw/synthetic/.gitkeep
!data/processed/clean/.gitkeep
!data/processed/moderate/.gitkeep
!data/processed/heavy/.gitkeep

# Model weights
*.pt
*.pth
*.onnx
*.safetensors
*.bin

# Results - large files
results/metrics/*.csv
results/figures/*.png
results/figures/*.pdf

# But keep directory structure
!results/metrics/.gitkeep
!results/figures/.gitkeep
!results/reports/.gitkeep

# Logs
*.log
logs/

# API keys and secrets
.env
.env.local
.env.*.local
secrets.yaml
credentials.json

